<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gruppo Caviro | Il vigneto più grande d'Italia</title>
    
    <!-- CSS Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Colori aziendali Caviro */
        .bg-vino { background-color: #722F37 !important; color: white; }
        .text-vino { color: #722F37 !important; }
        .btn-vino { background-color: #722F37; color: white; border: none; }
        .btn-vino:hover { background-color: #5a252b; color: white; }
        
        /* Regolazione altezza carosello */
        .carousel-item img {
            height: 60vh;
            object-fit: cover;
            filter: brightness(60%);
        }
    </style>
</head>
<body class="bg-light">

    <!-- ========================================== -->
    <!-- NAVBAR (Menu di navigazione in alto)       -->
    <!-- ========================================== -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-vino sticky-top shadow">
        <div class="container">
            <!-- Logo ufficiale in SVG con filtro per farlo diventare bianco -->
            <a class="navbar-brand" href="index.html">
                <img src="Caviro-logo-60-scuro.svg" alt="Logo Gruppo Caviro" height="45" style="filter: brightness(0) invert(1);">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipale">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="menuPrincipale">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fs-5">
                    <li class="nav-item"><a class="nav-link active" href="index.html">Home & Report</a></li>
                    <li class="nav-item"><a class="nav-link" href="chi-siamo.html">La Nostra Storia</a></li>
                    <li class="nav-item"><a class="nav-link" href="economia-circolare.html">Economia Circolare</a></li>
                    <li class="nav-item"><a class="nav-link" href="dove-trovarci.html">Dove Trovarci</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ========================================== -->
    <!-- CAROUSEL (Slider Immagini)                 -->
    <!-- ========================================== -->
    <div id="caviroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#caviroCarousel" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#caviroCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#caviroCarousel" data-bs-slide-to="2"></button>
        </div>
        
        <div class="carousel-inner">
            <!-- Slide 1: Immagine WEBP -->
            <div class="carousel-item active" data-bs-interval="4000">
                <img src="Scheda-Vino.webp" class="d-block w-100" alt="I Vini Caviro">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="display-4 fw-bold">Il vigneto più grande d'Italia</h2>
                    <p class="fs-4">Oltre 36.200 ettari vitati e 11.500 viticoltori uniti dalla stessa passione.</p>
                </div>
            </div>
            
            <!-- Slide 2: Immagine funzionante -->
            <div class="carousel-item" data-bs-interval="4000">
                <img src="https://images.unsplash.com/photo-1560493676-04071c5f467b?q=80&w=2000&auto=format&fit=crop" class="d-block w-100" alt="Economia Circolare">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="display-4 fw-bold">Dalla Vigna alla Vigna</h2>
                    <p class="fs-4">Trasformiamo l'energia di ogni acino in valore per il pianeta, generando bioenergia e fertilizzanti naturali.</p>
                </div>
            </div>
            
            <!-- Slide 3 -->
            <div class="carousel-item" data-bs-interval="4000">
                <img src="https://images.unsplash.com/photo-1585553616435-2dc0a54e271d?q=80&w=2070&auto=format&fit=crop" class="d-block w-100" alt="Storia Caviro">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="display-4 fw-bold">60 Anni di Storia</h2>
                    <p class="fs-4">Dal 1966 esportiamo l'eccellenza del vino italiano nel mondo.</p>
                </div>
            </div>
        </div>
        
        <button class="carousel-control-prev" type="button" data-bs-target="#caviroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#caviroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <!-- ========================================== -->
    <!-- LEAD GENERATION (Download Report)          -->
    <!-- ========================================== -->
    <main class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                
                <div class="card shadow border-0 overflow-hidden">
                    <div class="row g-0 align-items-center">
                        
                        <!-- COLONNA SINISTRA: Copertina del Report -->
                        <div class="col-md-5 p-4 text-center bg-light border-end">
                            <img src="Bilancio-di-sostenibilita-2025-ita.webp" alt="Copertina Bilancio 2025" class="img-fluid rounded shadow-sm" style="max-height: 280px;">
                        </div>
                        
                        <!-- COLONNA DESTRA: Testi e Modulo Lead Generation -->
                        <div class="col-md-7 p-4 p-lg-5">
                            
                            <h2 class="fw-bold text-vino mb-3 fs-3"><i class="bi bi-file-earmark-pdf-fill"></i> Scarica l'ultimo Bilancio (2025)</h2>
                            <p class="text-muted mb-4 small">Scopri i nostri risultati ambientali e sociali più recenti. Inserisci i tuoi dati per ricevere il documento completo sul modello di economia circolare Caviro.</p>
                            
                            <form action="/download/report" method="GET">
                                <div class="row">
                                    <div class="col-sm-6 mb-3">
                                        <label for="nome" class="form-label fw-bold small">Nome Completo:</label>
                                        <input type="text" id="nome" name="nome" class="form-control" placeholder="Es. Mario Rossi" required>
                                    </div>
                                    <div class="col-sm-6 mb-4">
                                        <label for="email" class="form-label fw-bold small">Indirizzo Email:</label>
                                        <input type="email" id="email" name="email" class="form-control" placeholder="Es. mario.rossi@email.it" required>
                                    </div>
                                </div>
                                
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-vino btn-lg shadow-sm"><i class="bi bi-cloud-arrow-down"></i> Avvia il Download</button>
                                </div>
                            </form>

                            <!-- SEZIONE DISCRETA: Archivio vecchi report -->
                            <div class="mt-4 text-center border-top pt-3">
                                <div class="dropdown">
                                    <a href="#" class="text-muted small text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-archive"></i> Archivio report anni precedenti
                                    </a>
                                    <ul class="dropdown-menu shadow-sm fs-6 border-0">
                                        <li><a class="dropdown-item small" href="#"><i class="bi bi-file-pdf text-danger"></i> Bilancio di Sostenibilità 2024</a></li>
                                        <li><a class="dropdown-item small" href="#"><i class="bi bi-file-pdf text-danger"></i> Bilancio di Sostenibilità 2023</a></li>
                                        <li><a class="dropdown-item small" href="#"><i class="bi bi-file-pdf text-danger"></i> Bilancio di Sostenibilità 2022</a></li>
                                    </ul>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0">© 2026 Gruppo Caviro - Sviluppato per progetto didattico</p>
            <p class="small text-muted">Sede Legale: Via Convertite 8, Faenza (RA)</p>
        </div>
    </footer>

    <!-- Script Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>